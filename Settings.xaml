<Window x:Class="Jotter.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Jotter"
        mc:Ignorable="d"
        
        AllowsTransparency="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource WindowBorderBrush}"
        Foreground="{DynamicResource NoteTextForegroundBrush}"
        BorderThickness="5"
        Height="600" 
        Width="420"
        Title="Settings"
        Loaded="Window_Loaded"
        >

    <Window.Resources>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <ControlTemplate.Resources>
                        </ControlTemplate.Resources>
                        <Grid Background="Transparent" SnapsToDevicePixels="True" Height="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="markGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Fill="Transparent" Height="16" x:Name="moveEllipse">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation From="0" To="21" Duration="0:0:0.2" Storyboard.TargetProperty="Width" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation To="0" Duration="0:0:0.2" Storyboard.TargetProperty="Width"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <!-- rectangle with rounded ends. -->
                                <!-- Margin="1,4,1,4" Margin="1,1,-4,3" -->
                                <Rectangle RadiusX="6" RadiusY="6" 
                       Grid.ColumnSpan="2" 
                       Name="line" 
                       StrokeThickness=".8" 
                       IsHitTestVisible="False" Margin="1,1,-4,3">
                                    <Rectangle.Style>
                                        <Style TargetType="{x:Type Rectangle}">
                                            <Setter Property="Fill" Value="{DynamicResource ListViewBackgroundBrush}"/>
                                            <Setter Property="Stroke" Value="{DynamicResource WindowBorderBrush}"/>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <!-- the toggle round switch -->
                                <!-- Margin="3,3,0,5" -->
                                <Ellipse Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" 
                     StrokeThickness=".8" 
                     Name="spot" 
                     Grid.Column="1" 
                     HorizontalAlignment="Left" Margin="3,3,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource ListViewBackgroundBrush}"/>
                                            <Setter Property="Stroke" Value="{DynamicResource ListViewBackgroundBrush}"/>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Grid>
                            <ContentPresenter x:Name="contentPresenter" ContentTemplate="{TemplateBinding ContentTemplate}" Grid.Column="1" ContentStringFormat="{TemplateBinding ContentStringFormat}" Focusable="False" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter.Content>
                                    <!-- ON/OFF text here-->
                                    <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe UI Semibold" Margin="8,1,0,0" FontSize="11" Foreground="{DynamicResource NoteTextForegroundBrush}"/>
                                </ContentPresenter.Content>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Stroke" TargetName="line" Value="{DynamicResource SelectedNoteBorderBrush}"/>
                                <Setter Property="Stroke" TargetName="spot" Value="{DynamicResource SelectedNoteBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity"  Value=".5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Stroke" TargetName="line" Value="{DynamicResource WindowBorderBrush}"/>
                                <Setter Property="Stroke" TargetName="spot" Value="{DynamicResource WindowBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Fill" TargetName="line" Value="{DynamicResource SelectedNoteBackgroundBrush}"/>
                                <Setter Property="Fill" TargetName="spot" Value="{DynamicResource HeaderBackgroundBrush}"/>
                                <Setter Property="Stroke" TargetName="spot" Value="{DynamicResource SelectedNoteBackgroundBrush}"/>
                                <Setter Property="Tag" Value="ON" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Fill" TargetName="line" Value="{DynamicResource HeaderBackgroundBrush}"/>
                                <Setter Property="Tag" Value="OFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for the headers -->
        <Style TargetType="TextBlock" x:Key="SettingsTitle">
            <Setter Property="Text" Value="Jotter" />
            <Setter Property="Foreground" Value="{DynamicResource HeaderForegroundBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="5,2,2,7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="HeaderTextStyle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,10,0,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource NoteTextForegroundBrush}"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="GeneralTextStyle">
            <Setter Property="Margin" Value="5,10,0,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource NoteTextForegroundBrush}"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource NoteTextForegroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Style for the separators -->
        <Style TargetType="Separator" x:Key="SeparatorStyle">
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowBorderBrush}"/>
        </Style>

        <!-- Style for the buttons -->
        <Style TargetType="Button" x:Key="ButtonStyle">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="0,10,10,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Button" x:Key="ExportActionButtonStyle">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource NoteTitleForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SelectedNoteBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedNoteBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ExportButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExportButtonBorder" Property="Background" Value="{DynamicResource NoteBlockBackgroundBrush}"/>
                                <Setter TargetName="ExportButtonBorder" Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ExportButtonBorder" Property="Background" Value="{DynamicResource NoteBlockBorderBrush}"/>
                                <Setter TargetName="ExportButtonBorder" Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem" x:Key="SettingsComboBoxItemStyle">
            <Setter Property="Foreground" Value="{DynamicResource NoteEditForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource NoteEditBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MainGridBackgroundBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SelectedNoteBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NoteEditBackgroundBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SelectedNoteBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" x:Key="SettingsComboBoxStyle">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="12,4,36,4"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource NoteEditForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource NoteEditBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NoteBlockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    <Border Width="28"
                                            Margin="0,3,4,3"
                                            HorizontalAlignment="Right"
                                            CornerRadius="6"
                                            Background="{DynamicResource MainGridBackgroundBrush}"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="v"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource NoteEditForegroundBrush}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Rectangle Fill="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource NoteEditBackgroundBrush}"
                                        BorderBrush="{DynamicResource SelectedNoteBorderBrush}"
                                        BorderThickness="1.5"
                                        CornerRadius="8">
                                    <ScrollViewer Margin="2"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="FilePathTextStyle">
            <Setter Property="Margin" Value="5,2,0,2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource NoteTextForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ListViewBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinWidth" Value="300"/>
            <!--<Setter Property="IsReadOnly" Value="True"/>-->
            <!-- Blue color for file paths -->
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HeaderBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <TextBlock Text="X"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background" Value="{StaticResource Button.MouseOver.Background}"/>
                                <Setter TargetName="CloseBorder" Property="BorderBrush" Value="{StaticResource Button.MouseOver.Border}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background" Value="{StaticResource Button.Pressed.Background}"/>
                                <Setter TargetName="CloseBorder" Property="BorderBrush" Value="{StaticResource Button.Pressed.Border}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CloseBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Width" Value="10" />
        </Style>

    </Window.Resources>

    <!-- Background="#FF333333" -->
    <Grid x:Name="GlobalSettingsGrid" Grid.Row="0" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="273*"/>
            <ColumnDefinition Width="137*"/>
        </Grid.ColumnDefinitions>

        <!-- Close Button -->
        <Grid x:Name="TopBorderGrid" MouseDown="TopBorderGrid_MouseDown" Background="{DynamicResource HeaderBackgroundBrush}" Grid.ColumnSpan="2" >
            <TextBlock Name="StickyNotesSettingsTitle" Style="{StaticResource SettingsTitle}"/>
            <Button x:Name="CloseSettings" Click="CloseSettings_Click" Style="{StaticResource CloseButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="1"/>
        </Grid>

        <!-- TODO 
        GlobalSettingsGrid and TopBorderGrid I'm a bit troubled on. TopBorerGRid has a maxwidth of 700 and that's just to get the "border band" to extend to end of window.
        If it were not setting the ScrollViewerMain's background color, then the whole window will be TopBorderGrid's background.
        The whole grid may have to be re-done to have a partition to separate the ScrollViewerMain from TopBorderGrid.
        This is a bit tricky because GlobalSettingsGrid was originally placed because of an error complaing about a grid placed before ScrollViewerMain saying a child window was defined, or something. 
        The whole settings, at the time, of this writing, was a bit of a challenge to create esepcially the toggleswitches. 
        I still get annoying UI errors causing me to clean/rebuild/clean, rebuild. And when I think the problem has gone
        away, I had made changes to "fix" a problem in cache. Ended up closing VS2022 and restarting to get it to behave after clean builds.
        So... yeah, settings UI grid layouts may need to get re-done.
        -->
        <ScrollViewer x:Name="ScrollViewerMain" VerticalScrollBarVisibility="Auto" Margin="0,35,0,0" Background="{DynamicResource WindowBackgroundBrush}" Grid.ColumnSpan="2">

            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="61*"/>
                    <ColumnDefinition Width="59*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- General Settings -->
                <TextBlock Grid.Row="0" Text="General Settings" Style="{StaticResource HeaderTextStyle}" Grid.ColumnSpan="2"/>
                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="User data: " Style="{StaticResource GeneralTextStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TextUserData" 
                             Text="{Binding txtUserData, Mode=TwoWay, UpdateSourceTrigger=LostFocus, TargetNullValue=C:\MyApp\SaveFile}" 
                             Style="{StaticResource FilePathTextStyle}" 
                             VerticalAlignment="Center" 
                             IsReadOnly="True"
                             LostFocus="TextUserData_LostFocus"/>
                    <Button Grid.Column="2" x:Name="btnBrowseUserData" Content="Browse..." Margin="8,2,0,2" Style="{StaticResource ExportActionButtonStyle}" Width="92" Click="btnBrowseUserData_Click"/>
                </Grid>

                <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Log path:  " Style="{StaticResource GeneralTextStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TextLogFile" 
                             Text="{Binding txtLogFile, Mode=TwoWay, UpdateSourceTrigger=LostFocus, TargetNullValue=C:\Logs\logfile.txt}" 
                             Style="{StaticResource FilePathTextStyle}" 
                             VerticalAlignment="Center"
                             LostFocus="TextLogFile_LostFocus"/>
                </Grid>



                <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="Enable logging" VerticalAlignment="Center" Margin="5,0,10,0"/>
                            <CheckBox x:Name="chkEnableLogging" Width="62" VerticalAlignment="Center" IsChecked="True" Checked="chkEnableLogging_Checked" Unchecked="chkEnableLogging_Unchecked"/>
                        </StackPanel>
                        <Button Grid.Row="1" x:Name="btnOpenLog" Content="Open log" Width="92" HorizontalAlignment="Left" Margin="5,6,0,0" Style="{StaticResource ExportActionButtonStyle}" Click="btnOpenLog_Click" Visibility="Collapsed"/>
                    </Grid>
                </Grid>






                <Separator Grid.Row="4" Style="{StaticResource SeparatorStyle}" Grid.ColumnSpan="2" Margin="0,5,0,5"/>

                <!-- Application behavior
                Tried binding to settings, but not sure if it worked:
                IsChecked="{Binding Path=Settings.IsTray}"
                Update: under the constructor, add this context:
                DataContext = settingsManager;
                -->
                <TextBlock Grid.Row="5" Text="Application behavior:" Style="{StaticResource HeaderTextStyle}" Grid.ColumnSpan="2"/>
                <StackPanel x:Name="stackPanel_ExitBehavior" Grid.Row="5" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,45,0,0" Grid.RowSpan="2">
                    <RadioButton x:Name="rb_MinimizeToTray" Content="Minimize to tray" IsChecked="False" Margin="8,5,10,5" Checked="CheckedMinimizeToTray" GroupName="ExitBehavior"/>
                    <RadioButton x:Name="rb_FullExit" Content="Fully exit" IsChecked="True" Margin="0,5,0,0" Checked="CheckedFullExit" GroupName="ExitBehavior"/>
                </StackPanel>

                <!-- Set number of seconds for auto save 
                Adding a Tag property to each cb item stores the value we select:
                -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,50,0,8">
                    <TextBlock Text="Set number of seconds for auto save: " Style="{StaticResource GeneralTextStyle}" VerticalAlignment="Center" Margin="5,8,0,5"/>
                    <ComboBox x:Name="AutoSave" SelectedIndex="0" Margin="5,5,0,5" Width="150" IsEnabled="True" Style="{StaticResource SettingsComboBoxStyle}" SelectionChanged="cb_AutoSaveValChanged">
                        <ComboBoxItem Tag="3">Auto [3 seconds]</ComboBoxItem>
                        <ComboBoxItem Tag="25">25 seconds</ComboBoxItem>
                        <ComboBoxItem Tag="45">45 seconds</ComboBoxItem>
                        <ComboBoxItem Tag="60">60 seconds</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Themes -->
                <Separator Grid.Row="7" Style="{StaticResource SeparatorStyle}" Grid.ColumnSpan="2" Margin="0,5,0,5"/>

                <TextBlock Grid.Row="8" Text="Themes" Style="{StaticResource HeaderTextStyle}" Grid.ColumnSpan="2"/>

                <StackPanel Grid.Row="9" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,0,0,11">
                    <TextBlock Text="Theme: " Style="{StaticResource GeneralTextStyle}" VerticalAlignment="Center" Margin="5,5,0,5"/>
                    <ComboBox x:Name="ThemeSelection" SelectedIndex="0" Width="180" Margin="5,5,0,5" Style="{StaticResource SettingsComboBoxStyle}" SelectionChanged="cb_ThemeSelectionChanged">
                        <ComboBoxItem>Light Theme</ComboBoxItem>
                        <ComboBoxItem>Dark Theme</ComboBoxItem>
                        <ComboBoxItem>Default Theme</ComboBoxItem>
                    </ComboBox>
                    <Button x:Name="btnOpenThemesFolder" Content="Open folder" Margin="8,5,0,5" Style="{StaticResource ExportActionButtonStyle}" Width="102" Click="btnOpenThemesFolder_Click" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Note Options -->
                <Separator Grid.Row="10" Style="{StaticResource SeparatorStyle}" Grid.ColumnSpan="2" Margin="0,5,0,5"/>
                <TextBlock Grid.Row="11" Text="Note Options" Style="{StaticResource HeaderTextStyle}" Grid.ColumnSpan="2"/>

                <StackPanel Grid.Row="11" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,45,0,0" Grid.RowSpan="2">
                    <TextBlock Text="Add date/time stamps to notes: " VerticalAlignment="Center"/>
                    <CheckBox x:Name="chkDateTimeStamp" Margin="5,5,0,5" IsChecked="True" Checked="chkDateTimeStamp_Checked" Unchecked="chkDateTimeStamp_Unchecked"/>
                </StackPanel>

                <StackPanel Grid.Row="12" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,45,0,0" Grid.RowSpan="2">
                    <TextBlock Text="Confirm deletion of notes: " VerticalAlignment="Center"/>
                    <CheckBox x:Name="chkDeletionConfirm" Margin="5,5,0,5" IsChecked="True" Checked="chkDeletionConfirm_Checked" Unchecked="chkDeletionConfirm_Unchecked" />
                </StackPanel>

                <!-- Logging -->
                <!--<Separator Grid.Row="14" Style="{StaticResource SeparatorStyle}" Grid.ColumnSpan="2" Margin="0,5,0,5"/>
                <TextBlock Grid.Row="15" Text="Logging" Style="{StaticResource HeaderTextStyle}" Grid.ColumnSpan="2"/>

                <StackPanel Grid.Row="16" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,0,0,11" Grid.RowSpan="2">
                    <TextBlock Text="Enable logging" VerticalAlignment="Center"/>
                    <CheckBox Margin="5,5,0,5"/>
                </StackPanel>-->

                <!-- Save and Cancel buttons remove these later  - finally have a closing button working
                Place holders at the moment 
                -->
                <Separator Grid.Row="17" Style="{StaticResource SeparatorStyle}" Grid.ColumnSpan="2" Margin="0,5,0,5"/>

                <Border Grid.Row="18"
                        Grid.ColumnSpan="2"
                        Margin="0,8,0,8"
                        Padding="12"
                        CornerRadius="10"
                        Background="{DynamicResource NoteBlockBackgroundInnerBrush}"
                        BorderBrush="{DynamicResource NoteBlockBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Markdown export"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="14"
                                       Foreground="{DynamicResource NoteTitleForegroundBrush}"/>
                            <TextBlock Text="Save every note as its own .md file in a folder you choose."
                                       Margin="0,4,0,0"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource NoteTextForegroundBrush}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                x:Name="btnExportNotes"
                                Content="Export Notes"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource ExportActionButtonStyle}"
                                Click="btnExportNotes_Click"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="19" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,28,0,0" Grid.RowSpan="2">
                    <TextBlock Text="Version: " VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionTextBlock" Text="???" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="20" Orientation="Horizontal" Grid.ColumnSpan="2" Grid.RowSpan="4">
                    <!--<Button Content="Save" Style="{StaticResource ButtonStyle}"/>
                    <Button Content="Cancel" Style="{StaticResource ButtonStyle}"/>-->
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>

</Window>
